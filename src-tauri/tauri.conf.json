{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TuneSoar",
  "version": "0.1.0",
  "identifier": "com.trancelab.tunesoar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "TuneSoar",
        "label": "main",
        "width": 420,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "skipTaskbar": false,
        "decorations": true,
        "minWidth": 360,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:*; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "TranceLab",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {}
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.tunesoar.com/releases/updater/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5M0ExRDY1Qjc0MjFDNwpSV1RISVhSYjFxR1RENFA3UERGYnRCd0pDYVdOV0NPbFI2bjRMNHJSNzRmcklCN3pOR1lqTHB3Qwo="
    }
  }
}
