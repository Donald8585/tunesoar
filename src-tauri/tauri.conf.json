{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TuneSoar",
  "version": "0.2.7",
  "identifier": "com.wealthmakermasterclass.tunesoar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "TuneSoar",
        "label": "main",
        "width": 420,
        "height": 640,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "skipTaskbar": false,
        "decorations": true,
        "minWidth": 360,
        "minHeight": 500,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net https://*.clerk.accounts.dev https://*.clerk.com https://clerk.tunesoar.com; connect-src 'self' http://localhost:* ws://localhost:* https://api.clerk.com https://*.clerk.accounts.dev https://*.clerk.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://img.clerk.com https://*.clerk.com; frame-src 'self' https://*.clerk.accounts.dev https://*.clerk.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "Wealth Maker Masterclass Limited",
    "category": "Utility",
    "shortDescription": "Context-aware binaural beats desktop app",
    "longDescription": "TuneSoar automatically switches binaural beat profiles based on what you're doing \u2014 coding, writing, gaming, reading, or relaxing. Features 12 context types, 5 brainwave bands, auto-pause, sleep mode, and custom mappings. Runs quietly in your system tray.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      },
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libssl3",
          "libgtk-3-0",
          "libasound2"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://api.tunesoar.com/releases/updater/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNCRDZEQkVCMkY5NDg2NzEKUldSeGhwUXY2OXZXT3pad0kzZ0dJTkNIK1NQWXZzbzZINEVWZ2VKN0RabHhyRVVvRzNqVlRjUzEK"
    }
  }
}
